# Backend Environment Variables
# Copy this file to ../.env (root) or configure in your deployment environment

NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_tower
DB_USER=postgres
DB_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info

# Nexus IQ (optional)
NEXUS_IQ_URL=
NEXUS_IQ_USERNAME=
NEXUS_IQ_TOKEN=
