# Backend Environment Variables
# Copy this file to ../.env (root) or configure in your deployment environment

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_tower
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000

# Redis (BullMQ queues + caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info


# Nexus IQ (optional — leave blank to skip sync)
NEXUS_IQ_URL=https://soft-security:8070
NEXUS_IQ_USERNAME=admin
NEXUS_IQ_TOKEN=
