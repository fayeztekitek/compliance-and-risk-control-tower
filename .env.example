# ============================================================================
# Compliance & Risk Control Tower — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compliance_tower
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Authentication ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100


# --- Sonatype Nexus IQ (optional) ---
NEXUS_IQ_URL=
NEXUS_IQ_USERNAME=
NEXUS_IQ_TOKEN=

# --- Logging ---
LOG_LEVEL=debug

# --- Frontend ---
VITE_API_URL=http://localhost:3000
